{
  "$ref": "#/definitions/ChannelMeta",
  "definitions": {
    "ChannelMeta": {
      "type": "object",
      "properties": {
        "channelId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "includes": {
          "type": "string"
        },
        "members": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "acpVersion": {
                "type": "string"
              },
              "agentId": {
                "type": "string"
              },
              "cliVersion": {
                "type": "string"
              },
              "joinedAt": {
                "type": "string",
                "format": "date-time"
              },
              "lastTurnAt": {
                "type": "string",
                "format": "date-time"
              },
              "status": {
                "type": "string",
                "enum": [
                  "idle",
                  "thinking",
                  "awaiting_permission",
                  "errored",
                  "muted",
                  "left",
                  "acp_incompatible"
                ]
              }
            },
            "required": [
              "agentId",
              "joinedAt",
              "status"
            ],
            "additionalProperties": false
          }
        },
        "scope": {
          "type": "string",
          "enum": [
            "project",
            "global",
            "isolated"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "archived",
            "disposed"
          ]
        },
        "treeRoot": {
          "type": "string"
        },
        "turnCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "channelId",
        "createdAt",
        "members",
        "scope",
        "status",
        "treeRoot",
        "turnCount"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
