{
  "$ref": "#/definitions/LookbackPacket",
  "definitions": {
    "LookbackPacket": {
      "type": "object",
      "properties": {
        "channelId": {
          "type": "string"
        },
        "currentPrompt": {
          "type": "string"
        },
        "sharedArtifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "factId": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "version": {
                "type": "integer"
              }
            },
            "required": [
              "factId",
              "path",
              "version"
            ],
            "additionalProperties": false
          }
        },
        "sinceYourLastTurn": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "by": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "message",
                  "artifact",
                  "review",
                  "digest"
                ]
              },
              "path": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "summary": {
                "type": "string"
              },
              "turnId": {
                "type": "string"
              }
            },
            "required": [
              "by",
              "kind",
              "path",
              "summary",
              "turnId"
            ],
            "additionalProperties": false
          }
        },
        "yourLastTurn": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "agentId": {
                  "type": "string"
                },
                "artifactsTouched": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "channelId": {
                  "type": "string"
                },
                "endedAt": {
                  "type": "string",
                  "format": "date-time"
                },
                "hostsContacted": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "promptedBy": {
                  "type": "string",
                  "enum": [
                    "user",
                    "agent"
                  ]
                },
                "promptText": {
                  "type": "string"
                },
                "startedAt": {
                  "type": "string",
                  "format": "date-time"
                },
                "state": {
                  "type": "string",
                  "enum": [
                    "submitted",
                    "routing",
                    "in_flight",
                    "awaiting_permission",
                    "expired",
                    "completed",
                    "failed",
                    "cancelled"
                  ]
                },
                "tokensUsed": {
                  "type": "integer",
                  "minimum": 0
                },
                "toolCallCount": {
                  "type": "integer",
                  "minimum": 0
                },
                "turnId": {
                  "type": "string"
                }
              },
              "required": [
                "agentId",
                "channelId",
                "promptText",
                "startedAt",
                "state",
                "turnId"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "channelId",
        "currentPrompt",
        "sharedArtifacts",
        "sinceYourLastTurn",
        "yourLastTurn"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
