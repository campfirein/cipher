{
  "name": "byterover-cli",
  "description": "ByteRover's CLI",
  "version": "0.0.0",
  "author": "ByteRover",
  "bin": {
    "br": "./bin/run.js"
  },
  "bugs": "https://github.com/campfirein/byterover-cli/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "axios": "^1.12.2",
    "express": "^5.1.0",
    "keytar": "^7.9.0",
    "open": "^10.2.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/express": "^5.0.3",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@types/sinon": "^17.0.4",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^10",
    "nock": "^14.0.10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "sinon": "^21.0.0",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/campfirein/byterover-cli",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "br",
    "dirname": "br",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " ",
    "topics": {
      "hello": {
        "description": "Say hello to the world and others"
      }
    }
  },
  "repository": "campfirein/byterover-cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "build:dev": "BR_BUILD_ENV=development npm run build",
    "build:prod": "BR_BUILD_ENV=production npm run build",
    "lint": "eslint",
    "pack:dev": "BR_BUILD_ENV=development oclif pack tarballs",
    "pack:prod": "BR_BUILD_ENV=production oclif pack tarballs",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
