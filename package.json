{
  "name": "byterover-cli",
  "description": "ByteRover's CLI",
  "version": "0.2.1",
  "author": "ByteRover",
  "bin": {
    "brv": "./bin/run.js"
  },
  "bugs": "https://github.com/campfirein/byterover-cli/issues",
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.13",
    "@inquirer/prompts": "^7.9.0",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "axios": "^1.12.2",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "express": "^5.1.0",
    "glob": "^11.0.3",
    "keytar": "^7.9.0",
    "mixpanel": "^0.18.1",
    "nanoid": "^5.1.6",
    "open": "^10.2.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/express": "^5.0.3",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@types/sinon": "^17.0.4",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^10",
    "nock": "^14.0.10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "sinon": "^21.0.0",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://www.byterover.dev/",
  "keywords": [],
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "brv",
    "dirname": "brv",
    "commands": "./dist/commands",
    "hooks": {
      "init": "./dist/hooks/init/welcome"
    },
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {
      "space": {
        "description": "Manage ByteRover spaces"
      }
    }
  },
  "repository": "campfirein/byterover-cli",
  "scripts": {
    "build": "shx rm -rf dist && shx rm -f tsconfig.tsbuildinfo && tsc && shx cp -r src/templates dist/templates && shx cp src/infra/cipher/grpc/internal-llm-grpc.proto dist/infra/cipher/grpc/",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "npm run build && oclif manifest",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "git add README.md"
  },
  "types": "dist/index.d.ts"
}
