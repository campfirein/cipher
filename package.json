{
  "name": "byterover-cli",
  "description": "ByteRover's CLI",
  "version": "1.0.3",
  "author": "ByteRover",
  "bin": {
    "brv": "./bin/run.js"
  },
  "bugs": "https://github.com/campfirein/byterover-cli/issues",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.1",
    "@anthropic-ai/vertex-sdk": "^0.14.0",
    "@google/genai": "^1.29.0",
    "@inkjs/ui": "^2.0.0",
    "@inquirer/prompts": "^7.9.0",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@socket.io/admin-ui": "^0.5.1",
    "@types/update-notifier": "^6.0.8",
    "axios": "^1.12.2",
    "better-sqlite3": "^11.5.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "express": "^5.1.0",
    "fullscreen-ink": "^0.1.0",
    "glob": "^11.0.3",
    "gradient-string": "^3.0.0",
    "ignore": "^7.0.5",
    "ink": "^6.5.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer-file-selector": "^1.0.1",
    "js-yaml": "^4.1.1",
    "keytar": "^7.9.0",
    "mixpanel": "^0.18.1",
    "nanoid": "^5.1.6",
    "open": "^10.2.0",
    "openai": "^6.9.1",
    "react": "^19.2.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "update-notifier": "^7.3.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^4",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10",
    "@types/node": "^20",
    "@types/react": "^19.2.7",
    "@types/sinon": "^17.0.4",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "expect-type": "^1.2.2",
    "mocha": "^10",
    "nock": "^14.0.10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "sinon": "^21.0.0",
    "ts-node": "^10",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://www.byterover.dev/",
  "keywords": [],
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "brv",
    "dirname": "brv",
    "commands": "./dist/commands",
    "hooks": {
      "init": [
        "./dist/hooks/init/welcome",
        "./dist/hooks/init/update-notifier"
      ],
      "command_not_found": "./dist/hooks/command_not_found/handle-invalid-commands",
      "error": "./dist/hooks/error/clean-errors",
      "prerun": "./dist/hooks/prerun/validate-brv-config-version"
    },
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {
      "space": {
        "description": "Manage ByteRover spaces"
      }
    }
  },
  "repository": "campfirein/byterover-cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b && shx cp -r src/templates dist/templates && shx cp -r src/resources dist/resources",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "npm run build && BRV_ENV=production oclif manifest",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "git add README.md"
  },
  "types": "dist/index.d.ts"
}
