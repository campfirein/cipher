{
  "name": "@brv/agent-sdk",
  "version": "0.1.0",
  "description": "Thin ergonomic wrapper over the Agent Client Protocol for building agents that join brv channels.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
