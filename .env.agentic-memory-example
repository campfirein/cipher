# A-MEM (Agentic Memory) Configuration Example
# Copy this to your .env file and modify as needed

# =============================================================================
# A-MEM MODE CONFIGURATION
# =============================================================================

# Enable A-MEM system
AGENTIC_MEMORY_ENABLED=true

# A-MEM Mode:
# - disabled: A-MEM is completely disabled (default)
# - enabled: A-MEM is enabled with standard configuration
# - memagent: A-MEM is enabled with memAgent-specific configuration and collections
AGENTIC_MEMORY_MODE=enabled

# =============================================================================
# STANDARD A-MEM CONFIGURATION (when AGENTIC_MEMORY_MODE=enabled)
# =============================================================================

# Collection names for memory storage
AGENTIC_MEMORY_COLLECTION=agentic_memories
AGENTIC_MEMORY_EVOLUTION_COLLECTION=agentic_memory_evolution

# Evolution settings
AGENTIC_MEMORY_EVOLUTION_THRESHOLD=100
AGENTIC_MEMORY_MAX_RELATED=5
AGENTIC_MEMORY_SIMILARITY_THRESHOLD=0.7
AGENTIC_MEMORY_AUTO_EVOLUTION=true

# Search settings
AGENTIC_MEMORY_MAX_SEARCH_RESULTS=10

# Performance settings
AGENTIC_MEMORY_BATCH_SIZE=100
AGENTIC_MEMORY_LLM_TIMEOUT=30000
AGENTIC_MEMORY_VECTOR_TIMEOUT=10000
AGENTIC_MEMORY_MAX_RETRIES=3

# Feature settings
AGENTIC_MEMORY_ANALYTICS_ENABLED=true
AGENTIC_MEMORY_DEBUG_MODE=false

# =============================================================================
# MEMAGENT A-MEM CONFIGURATION (when AGENTIC_MEMORY_MODE=memagent)
# =============================================================================

# Distinct collections for memAgent usage
MEMAGENT_AGENTIC_MEMORY_COLLECTION=memagent_agentic_memories
MEMAGENT_AGENTIC_MEMORY_EVOLUTION_COLLECTION=memagent_agentic_memory_evolution

# MemAgent-specific settings (optimized for agent conversations)
MEMAGENT_AGENTIC_MEMORY_EVOLUTION_THRESHOLD=50
MEMAGENT_AGENTIC_MEMORY_MAX_RELATED=10
MEMAGENT_AGENTIC_MEMORY_AUTO_EVOLUTION=true

# =============================================================================
# REQUIRED DEPENDENCIES
# =============================================================================

# Vector Store Configuration (required for A-MEM)
VECTOR_STORE_TYPE=qdrant
VECTOR_STORE_HOST=localhost
VECTOR_STORE_PORT=6333
VECTOR_STORE_COLLECTION=default
VECTOR_STORE_DIMENSION=1536

# LLM Configuration (required for content analysis and evolution)
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# USAGE EXAMPLES
# =============================================================================

# Example 1: Basic A-MEM for general use
# AGENTIC_MEMORY_MODE=enabled
# AGENTIC_MEMORY_COLLECTION=my_memories
# AGENTIC_MEMORY_EVOLUTION_THRESHOLD=200

# Example 2: A-MEM for memAgent with aggressive evolution
# AGENTIC_MEMORY_MODE=memagent
# MEMAGENT_AGENTIC_MEMORY_EVOLUTION_THRESHOLD=25
# MEMAGENT_AGENTIC_MEMORY_MAX_RELATED=15

# Example 3: A-MEM with Milvus backend
# VECTOR_STORE_TYPE=milvus
# VECTOR_STORE_HOST=localhost
# VECTOR_STORE_PORT=19530
# AGENTIC_MEMORY_MODE=enabled

# =============================================================================
# TOOL AVAILABILITY
# =============================================================================

# When A-MEM is enabled, the following tools become available:
# - add_memory_note: Add new memories with automatic analysis
# - search_agentic_memory: Search memories with evolution relationships
# - evolve_memory: Manually trigger memory evolution
# - get_memory_relationships: Query memory connections
# - consolidate_memories: Batch process memory evolution
# - update_memory_note: Update existing memories
# - delete_memory_note: Remove memories and relationships
# - memory_analytics: Get system statistics and insights

# =============================================================================
# COLLECTION SEPARATION
# =============================================================================

# The A-MEM system uses separate collections from cipher's existing memory:
# - Standard mode: Uses 'agentic_memories' and 'agentic_memory_evolution' collections
# - MemAgent mode: Uses 'memagent_agentic_memories' and 'memagent_agentic_memory_evolution' collections
# - Existing cipher memory: Uses 'default' and 'reflection_memory' collections

# This ensures no conflicts with existing memory systems while providing
# advanced agentic memory capabilities.