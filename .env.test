# Test configuration for A-MEM integration
AGENTIC_MEMORY_ENABLED=true
AGENTIC_MEMORY_MODE=memagent

# Required dependencies
VECTOR_STORE_TYPE=in-memory
VECTOR_STORE_COLLECTION=test_collection
VECTOR_STORE_DIMENSION=1536

# OpenAI API key (replace with your actual key)
OPENAI_API_KEY=your_openai_key_here

# Optional: Debug mode
AGENTIC_MEMORY_DEBUG_MODE=true
CIPHER_LOG_LEVEL=debug